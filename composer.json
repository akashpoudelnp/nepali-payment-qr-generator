{
    "name": "akashpoudelnp/nepali-payment-qr-generator",
    "description": "Generate and parse Nepali payment QR codes (Fonepay, eSewa, etc.)",
    "type": "library",
    "license": "MIT",
    "keywords": ["nepali", "payment", "qr", "fonepay", "emvco", "qr-code"],
    "homepage": "https://github.com/akashpoudelnp/nepali-payment-qr-generator",
    "support": {
        "issues": "https://github.com/akashpoudelnp/nepali-payment-qr-generator/issues",
        "source": "https://github.com/akashpoudelnp/nepali-payment-qr-generator"
    },
    "autoload": {
        "psr-4": {
            "Akashpoudelnp\\NepaliPaymentQrGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Akashpoudelnp\\NepaliPaymentQrGenerator\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Aakash Poudel",
            "email": "akashpoudelnp@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "chillerlan/php-qrcode": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "suggest": {
        "ext-gd": "Required for PNG QR code image generation"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=2G",
        "check": ["@test", "@analyse"]
    },
    "config": {
        "sort-packages": true
    }
}
